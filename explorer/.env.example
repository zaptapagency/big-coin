# BigCoin explorer environment variables (copy into Railway → Variables)

# --- Demo mode -------------------------------------------------------------
# Set to 1 to serve realistic sample data with NO chain backend (great for a
# first deploy / public demo). Set to 0 (or remove) to talk to a real node.
DEMO_MODE=1

# --- Real node connection (only needed when DEMO_MODE=0) -------------------
# Point these at a publicly reachable bigcoind JSON-RPC endpoint.
BIGCOIN_RPC_HOST=your.node.public.ip
BIGCOIN_RPC_PORT=9445
BIGCOIN_RPC_USER=changeme
BIGCOIN_RPC_PASSWORD=changeme
BIGCOIN_RPC_TIMEOUT=8

# --- Display ---------------------------------------------------------------
BIGCOIN_NAME=BigCoin
BIGCOIN_TICKER=BIG
EXPLORER_LATEST_BLOCKS=15

# NOTE: Do NOT set EXPLORER_PORT on Railway. Railway injects $PORT and the
# start command binds gunicorn to it automatically.

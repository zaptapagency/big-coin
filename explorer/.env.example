# BigCoin explorer environment variables (copy into Railway → Variables)

# --- Demo mode -------------------------------------------------------------
# Set to 1 to serve realistic sample data with NO chain backend (great for a
# first deploy / public demo). Set to 0 (or remove) to talk to a real node.
DEMO_MODE=1

# --- Real node connection (only needed when DEMO_MODE=0) -------------------
# Point these at a publicly reachable bigcoind JSON-RPC endpoint.
BIGCOIN_RPC_HOST=your.node.public.ip
BIGCOIN_RPC_PORT=9445
BIGCOIN_RPC_USER=changeme
BIGCOIN_RPC_PASSWORD=changeme
BIGCOIN_RPC_TIMEOUT=8

# --- Display ---------------------------------------------------------------
BIGCOIN_NAME=BigCoin
BIGCOIN_TICKER=BIG
EXPLORER_LATEST_BLOCKS=15

# NOTE: Do NOT set EXPLORER_PORT on Railway. Railway injects $PORT and the
# start command binds gunicorn to it automatically.

# --- Webhooks --------------------------------------------------------------
# A background poller delivers signed callbacks for new blocks and per-address
# activity. Registration (POST /api/webhooks) requires this API key; leave it
# unset to disable registration entirely (an unset key = no open relay).
WEBHOOK_API_KEY=change-me-to-a-long-random-string
# Optional tuning (defaults shown):
# WEBHOOKS_ENABLED=1
# WEBHOOK_POLL_INTERVAL=10
# WEBHOOK_MAX=200
# WEBHOOK_MAX_FAILURES=10
# WEBHOOK_TIMEOUT=8
# WEBHOOK_MAX_CATCHUP=50
# WEBHOOK_DB_PATH=webhooks.db
# Set to 1 ONLY for local testing — permits http + private/loopback callback
# URLs. Never enable on a public deployment (SSRF risk).
# WEBHOOK_ALLOW_PRIVATE=0
